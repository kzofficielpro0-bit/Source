local pulseStrokes = {}
local pulseFloat = 0

local function makePulseStroke(parent, baseThickness)
    local s = Instance.new("UIStroke")
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Thickness = baseThickness or 2
    s.Color = NEON
    s.Parent = parent
    table.insert(pulseStrokes, {stroke=s, base=baseThickness or 2})
    return s
end

RunService.RenderStepped:Connect(function(dt)
    pulseFloat = (pulseFloat + dt * 2) % (math.pi * 2)
    local pulse     = 1.5 + math.sin(pulseFloat * 4) * 1
    local intensity = 0.5 + math.sin(pulseFloat * 6) * 0.5
    local col = Color3.fromRGB(0, math.floor(200 + 55*intensity), math.floor(200 + 55*intensity))
    for _,entry in ipairs(pulseStrokes) do
        if entry.stroke and entry.stroke.Parent then
            entry.stroke.Thickness = entry.base * pulse
            entry.stroke.Color = col
        end
    end
end)

